FROM ubuntu:noble

RUN mkdir -p /run/systemd && echo 'docker' > /run/systemd/container
CMD ["/bin/bash"]
WORKDIR /ptarmigan

RUN apt-get -y update
RUN apt install -y python3 pip python3.12-venv
RUN python3 -m venv /python/venv-ptarmigan
RUN /python/venv-pyt-acc/bin/pip install ipython numpy
RUN /python/venv-pyt-acc/bin/pip install h5py jinja2

RUN apt update -y && \
    apt install -y build-essential &&\
    apt install -y git curl libhdf5-dev && \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs > sh.rustup.rs && \
    sh sh.rustup.rs -y &&\
    . $HOME/.cargo/env && \ 
    git clone https://github.com/tgblackburn/ptarmigan.git && \
    cd ptarmigan && \
    cargo build --release --features hdf5-output
    
